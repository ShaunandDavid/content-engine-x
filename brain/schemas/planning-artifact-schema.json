{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AdamPlanningArtifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "plan_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "workflow_run_id": { "type": "string", "format": "uuid" },
    "project_name": { "type": "string", "minLength": 3 },
    "source_idea": { "type": "string", "minLength": 20 },
    "normalized_user_goal": { "type": "string", "minLength": 5 },
    "audience": { "type": "string", "minLength": 3 },
    "offer_or_concept": { "type": "string", "minLength": 3 },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_angle": { "type": "string", "minLength": 10 },
    "next_step_planning_summary": { "type": "string", "minLength": 10 },
    "created_at": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "plan_id",
    "project_id",
    "workflow_run_id",
    "project_name",
    "source_idea",
    "normalized_user_goal",
    "audience",
    "offer_or_concept",
    "constraints",
    "recommended_angle",
    "next_step_planning_summary",
    "created_at",
    "metadata"
  ]
}
