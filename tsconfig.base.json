{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@content-engine/shared": ["packages/shared/src/index.ts"],
      "@content-engine/shared/*": ["packages/shared/src/*"],
      "@content-engine/db": ["packages/db/src/index.ts"],
      "@content-engine/db/*": ["packages/db/src/*"],
      "@content-engine/sora-provider": ["services/providers/sora/src/index.ts"],
      "@content-engine/sora-provider/*": ["services/providers/sora/src/*"]
    }
  }
}
