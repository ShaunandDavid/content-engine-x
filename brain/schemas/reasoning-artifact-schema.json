{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnochReasoningArtifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "reasoningId": { "type": "string", "format": "uuid" },
    "projectId": { "type": "string", "format": "uuid" },
    "workflowRunId": { "type": "string", "format": "uuid" },
    "createdAt": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requestClassification": { "type": "string", "minLength": 3 },
        "coreUserGoal": { "type": "string", "minLength": 5 },
        "explicitConstraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptionsOrUnknowns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasoningSummary": { "type": "string", "minLength": 10 }
      },
      "required": [
        "requestClassification",
        "coreUserGoal",
        "explicitConstraints",
        "assumptionsOrUnknowns",
        "reasoningSummary"
      ]
    }
  },
  "required": [
    "reasoningId",
    "projectId",
    "workflowRunId",
    "createdAt",
    "metadata",
    "reasoning"
  ]
}
