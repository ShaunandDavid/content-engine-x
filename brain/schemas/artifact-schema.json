{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "brain/schemas/artifact-schema.json",
  "title": "Enoch Artifact",
  "description": "Canonical persisted input or output record for Enoch.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "artifact_type": { "type": "string", "minLength": 1 },
    "artifact_role": { "type": "string", "enum": ["input", "working", "output"] },
    "status": {
      "type": "string",
      "enum": ["pending", "queued", "running", "awaiting_approval", "approved", "completed", "failed", "cancelled"]
    },
    "schema_name": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "string", "minLength": 1 },
    "content_ref": { "type": ["string", "null"] },
    "content": { "type": ["object", "array", "string", "number", "boolean", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object" }
  },
  "required": [
    "artifact_id",
    "tenant_id",
    "run_id",
    "artifact_type",
    "artifact_role",
    "status",
    "schema_name",
    "schema_version",
    "content_ref",
    "created_at",
    "metadata"
  ]
}
