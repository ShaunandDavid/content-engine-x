{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adam Voice Session State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "state",
    "input_mode",
    "output_mode",
    "last_updated_at",
    "metadata"
  ],
  "properties": {
    "session_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": ["string", "null"], "format": "uuid" },
    "run_id": { "type": ["string", "null"], "format": "uuid" },
    "turn_id": { "type": ["string", "null"], "format": "uuid" },
    "state": {
      "type": "string",
      "enum": ["idle", "listening", "thinking", "speaking", "error"]
    },
    "input_mode": {
      "type": "string",
      "enum": ["text", "speech_text"]
    },
    "output_mode": {
      "type": "string",
      "enum": ["text", "speech"]
    },
    "transcript": { "type": ["string", "null"] },
    "last_user_message": { "type": ["string", "null"] },
    "response_text": { "type": ["string", "null"] },
    "error_message": { "type": ["string", "null"] },
    "last_updated_at": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
