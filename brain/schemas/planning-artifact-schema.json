{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EnochPlanningArtifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "planId": { "type": "string", "format": "uuid" },
    "projectId": { "type": "string", "format": "uuid" },
    "workflowRunId": { "type": "string", "format": "uuid" },
    "projectName": { "type": "string", "minLength": 3 },
    "sourceIdea": { "type": "string", "minLength": 20 },
    "normalizedUserGoal": { "type": "string", "minLength": 5 },
    "audience": { "type": "string", "minLength": 3 },
    "offerOrConcept": { "type": "string", "minLength": 3 },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommendedAngle": { "type": "string", "minLength": 10 },
    "nextStepPlanningSummary": { "type": "string", "minLength": 10 },
    "reasoning": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requestClassification": { "type": "string", "minLength": 3 },
        "coreUserGoal": { "type": "string", "minLength": 5 },
        "explicitConstraints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptionsOrUnknowns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasoningSummary": { "type": "string", "minLength": 10 }
      },
      "required": [
        "requestClassification",
        "coreUserGoal",
        "explicitConstraints",
        "assumptionsOrUnknowns",
        "reasoningSummary"
      ]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "planId",
    "projectId",
    "workflowRunId",
    "projectName",
    "sourceIdea",
    "normalizedUserGoal",
    "audience",
    "offerOrConcept",
    "constraints",
    "recommendedAngle",
    "nextStepPlanningSummary",
    "reasoning",
    "createdAt",
    "metadata"
  ]
}
